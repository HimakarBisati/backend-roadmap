**W1-D5-Static_Methods_Employee**

**Today you learn:**
- `@staticmethod` — no `self`, no `cls`
- When to use static methods (validation, helper logic)

---

**1. Employee (continued)**

```python
class Employee:
    total_employees = 0
    company_name = "TechCorp"  # class variable, accessible without creating any object

    def __init__(self, name, salary):
        self.name = name
        self.salary = salary
        Employee.total_employees += 1
        if not self.is_valid_salary(salary):
            print("Warning: invalid salary")

    @classmethod
    def get_total_employees(cls):
        return cls.total_employees

    @staticmethod
    def is_valid_salary(salary):  # no self, no cls - doesn't need any object's data
        return salary > 0

    @staticmethod
    def calculate_bonus(salary, percentage):
        return salary * (percentage / 100)

    @staticmethod
    def is_valid_name(name):
        return name.isalpha() and len(name) > 0  # only letters, not empty

e1 = Employee("Ravi", 30000)
e2 = Employee("Sai", -5000)  # prints warning

print(Employee.is_valid_salary(e1.salary))      # True
print(Employee.calculate_bonus(30000, 10))      # 3000.0
print(Employee.is_valid_name("Ravi123"))        # False
print(Employee.company_name)                    # accessed without creating object
```

