**1. Class & Object**

```python
class Car:  # blueprint
    def __init__(self, brand, model, year):  # runs when object created
        self.brand = brand  # save to this object
        self.model = model
        self.year = year

    def display_info(self):  # method = function inside class
        print(f"{self.year} {self.brand} {self.model}")

    def is_new(self):
        return self.year >= 2023  # True or False

car1 = Car("Toyota", "Corolla", 2022)  # object 1
car2 = Car("Honda", "Civic", 2023)     # object 2

car1.display_info()  # 2022 Toyota Corolla
car2.display_info()  # 2023 Honda Civic
print(car1.is_new()) # False
print(car2.is_new()) # True
```

