**2. Person**

```python
class Person:
    def __init__(self, name, age, city):
        self.name = name  # save name on this person object
        self.age = age
        self.city = city

    def introduce(self):
        # uses this object's own saved data to print introduction
        print(f"Hi I'm {self.name}, {self.age}, from {self.city}")

    def is_adult(self):
        return self.age >= 18  # True if 18 or above, False if not

p1 = Person("Ravi", 22, "Hyderabad")
p1.introduce()       # Hi I'm Ravi, 22, from Hyderabad
print(p1.is_adult()) # True
```

