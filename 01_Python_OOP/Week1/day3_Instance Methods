**W1-D3-Instance_Methods_Student**

**Today you learn:**
- Methods calling other methods inside same class
- `return` vs `print`
- Decision making using object's own data

---

**1. Student**

```python
class Student:
    def __init__(self, name, marks):
        self.name = name
        self.marks = marks  # list [80, 45, 60]

    def average(self):
        return sum(self.marks) / len(self.marks)  # return sends value back to whoever called it

    def result(self):
        avg = self.average()  # calling another method inside same class
        if avg >= 40:
            return "Pass"
        else:
            return "Fail"

    def grade(self):
        avg = self.average()  # reusing average() instead of recalculating
        if avg >= 75:
            return "A"
        elif avg >= 60:
            return "B"
        elif avg >= 40:
            return "C"
        else:
            return "F"

    def highest_mark(self):
        return max(self.marks)  # max() finds highest in list

    def lowest_mark(self):
        return min(self.marks)  # min() finds lowest in list

s1 = Student("Ravi", [80, 45, 60])
s2 = Student("Sai", [30, 25, 35])

print(s1.name, s1.result(), s1.grade(), s1.highest_mark(), s1.lowest_mark())
print(s2.name, s2.result(), s2.grade(), s2.highest_mark(), s2.lowest_mark())
```

