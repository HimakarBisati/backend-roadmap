**W2-D2-Multiple_Inheritance_Employee**

**Today you learn:**
- `super()` — calling parent's method from child
- Child class adding extra attributes on top of parent

---

**1. Employee → Manager, Developer**

```python
class Employee:
    def __init__(self, name, salary):
        self.name = name
        self.salary = salary

    def info(self):
        print(f"{self.name} earns {self.salary}")


class Manager(Employee):
    def __init__(self, name, salary, team_size):
        super().__init__(name, salary)  # let parent set up name and salary
        self.team_size = team_size      # add extra attribute

    def info(self):
        super().info()  # run parent's info() first
        print(f"Manages a team of {self.team_size}")


class Developer(Employee):
    def __init__(self, name, salary, tech_stack):
        super().__init__(name, salary)
        self.tech_stack = tech_stack

    def info(self):
        super().info()
        print(f"Works with: {self.tech_stack}")


m1 = Manager("Ravi", 60000, 5)
d1 = Developer("Sai", 50000, "Python, Django")

m1.info()
d1.info()
```

